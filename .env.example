# ArbitEx — Environment template
# Copy to .env or .env.local and fill in values. Never commit real secrets.
# Config loads: .env.local first, then .env

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://arbitex:password@localhost:5432/arbitex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379

# ── Multi-chain RPC (private QuickNode/Alchemy URLs preferred) ───────────────────
# Set the RPC for your active chain (CHAIN_ID). All blockchain ops use these.
# docker-compose.yml has dev defaults; override here for production.

# Ethereum (chain 1)
ETHEREUM_RPC_URL=
ETHEREUM_ARCHIVE_RPC_URL=
ETHEREUM_WSS_URL=

# BSC (chain 56)
BSC_RPC_URL=

# Polygon (chain 137)
POLYGON_RPC_URL=

# Arbitrum (chain 42161)
ARBITRUM_RPC_URL=
ARBITRUM_WSS_URL=

# Base (chain 8453)
BASE_RPC_URL=
BASE_WSS_URL=

# Avalanche (chain 43114)
AVALANCHE_RPC_URL=
AVALANCHE_ARCHIVE_RPC_URL=
AVALANCHE_WSS_URL=

# Active chain (1=ETH, 56=BSC, 137=Polygon, 42161=Arbitrum, 8453=Base, 43114=Avalanche)
CHAIN_ID=1

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=min_32_chars_random_string_never_commit
JWT_EXPIRY=8h
OPERATOR_API_KEY=min_32_chars_for_api_key

# Login password (use one)
OPERATOR_PASSWORD_HASH=
# OPERATOR_PASSWORD=

# ── Worker (execution) ─────────────────────────────────────────────────────────
MOCK_EXECUTION=true
EXECUTION_WALLET_KEYSTORE_PATH=./infra/dev-keystore.json
EXECUTION_WALLET_KEYSTORE_PASS=
FLASHBOTS_AUTH_KEY=

# ── FlashArb Contract ──────────────────────────────────────────────────────────
# Deploy FlashArb.sol and set the address here to enable flash-loan arbitrage
FLASH_ARB_ADDRESS=
# Aave V3 PoolAddressesProvider (Avalanche mainnet default)
AAVE_POOL_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
DEFAULT_MAX_TRADE_SIZE_USD=1000
DEFAULT_MIN_NET_PROFIT_USD=5
DEFAULT_MAX_GAS_GWEI=100
