# Env files — never commit secrets
.env
.env.local
.env.prod
.env.secrets
.env.*.local

# Keystore files
infra/secrets/

# Dependencies
node_modules/
.pnpm-store/

# Build
dist/
.next/
*.tsbuildinfo

# TypeScript build output in source dirs (packages emit to src/)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# IDE / run configs
.idea/
.vscode/
.run/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
.logs/

# Test
coverage/
.nyc_output/
playwright-report/
test-results/
.github/workflows/deploy-vps.yml
