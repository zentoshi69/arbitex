# ── Domains / TLS (bitrunner3001.com) ──────────────────────────────────────────
# DNS nameservers: ns1.dns-parking.com, ns2.dns-parking.com
# Add A records: bitrunner3001.com and api.bitrunner3001.com → VPS public IP
ACME_EMAIL="you@bitrunner3001.com"
DASHBOARD_DOMAIN="bitrunner3001.com"
API_DOMAIN="api.bitrunner3001.com"

# Used by API CORS
DASHBOARD_ORIGIN="https://bitrunner3001.com"

# Used by Web app to reach API
NEXT_PUBLIC_API_URL="https://api.bitrunner3001.com"
NEXT_PUBLIC_WS_URL="wss://api.bitrunner3001.com"

# ── Database / Redis ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD="REPLACE_ME_LONG_RANDOM"
REDIS_PASSWORD="REPLACE_ME_LONG_RANDOM"

# If you keep Postgres/Redis in same compose, these can be:
DATABASE_URL="postgresql://arbitex:REPLACE_ME_LONG_RANDOM@postgres:5432/arbitex"
REDIS_URL="redis://:REPLACE_ME_LONG_RANDOM@redis:6379"

# ── API auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="REPLACE_ME_AT_LEAST_32_CHARS"
OPERATOR_API_KEY="REPLACE_ME_AT_LEAST_32_CHARS"

# Multi-user login: comma-separated plain-text passwords
OPERATOR_PASSWORD="REPLACE_ME_USER1,REPLACE_ME_USER2,REPLACE_ME_USER3"

# Alternative: bcrypt hashes (must escape $ as $$ for Docker Compose)
# OPERATOR_PASSWORD_HASHES="$$2b$$12$$hash1,$$2b$$12$$hash2,$$2b$$12$$hash3"

# ── Chain connectivity ────────────────────────────────────────────────────────
CHAIN_ID="43114"
ETHEREUM_RPC_URL=""
ETHEREUM_ARCHIVE_RPC_URL=""
AVALANCHE_RPC_URL="https://api.avax.network/ext/bc/C/rpc"

# ── FlashArb Contract (optional — leave empty until deployed) ─────────────
FLASH_ARB_ADDRESS=""
AAVE_POOL_PROVIDER="0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb"

# ── Execution flags ───────────────────────────────────────────────────────────
MOCK_EXECUTION="true"
LOG_LEVEL="info"

# ── Keystores (files on the VPS) ─────────────────────────────────────────────
EXECUTION_KEYSTORE_FILE="/opt/arbitex/secrets/execution-keystore.json"
EXECUTION_WALLET_KEYSTORE_PASS="REPLACE_ME"

SUPERADMIN_KEYSTORE_FILE="/opt/arbitex/secrets/superadmin-keystore.json"
SUPERADMIN_KEYSTORE_PASS="REPLACE_ME"

# Optional (if using Flashbots)
FLASHBOTS_AUTH_KEY=""
FLASHBOTS_RELAY_URL="https://relay.flashbots.net"
