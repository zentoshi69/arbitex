{
  "name": "arbitex",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-DEX arbitrage platform — operator use only",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "db:migrate": "pnpm --filter @arbitex/db migrate:deploy",
    "db:generate": "pnpm --filter @arbitex/db generate",
    "db:studio": "pnpm --filter @arbitex/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.3.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
