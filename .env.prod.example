# ArbitEx production env for bitrunner3001.com
# Copy to .env.prod and fill in values. Never commit .env.prod.

# ── Domains / TLS ─────────────────────────────────────────────────────────────
ACME_EMAIL=admin@bitrunner3001.com
DASHBOARD_DOMAIN=bitrunner3001.com
API_DOMAIN=api.bitrunner3001.com
DASHBOARD_ORIGIN=https://bitrunner3001.com
NEXT_PUBLIC_API_URL=https://api.bitrunner3001.com
NEXT_PUBLIC_WS_URL=wss://api.bitrunner3001.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=arbitex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=arbitex
DATABASE_URL=postgresql://arbitex:CHANGE_ME_STRONG_PASSWORD@postgres:5432/arbitex

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379

# ── Multi-chain RPC ───────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=
ETHEREUM_ARCHIVE_RPC_URL=
AVALANCHE_RPC_URL=
AVALANCHE_ARCHIVE_RPC_URL=
AVALANCHE_WSS_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
CHAIN_ID=43114

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_EXPIRY=8h
OPERATOR_API_KEY=CHANGE_ME_MIN_32_CHARS_FOR_API_KEY

# Login password — set OPERATOR_PASSWORD_HASH to a bcrypt hash to enable login.
# Generate: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
# IMPORTANT: double every $ for docker compose, e.g. $$2b$$12$$abc...
# Leave empty to disable login (public endpoints like /health and /market still work).
OPERATOR_PASSWORD_HASH=

# ── Worker (execution) ────────────────────────────────────────────────────────
MOCK_EXECUTION=true
EXECUTION_WALLET_KEYSTORE_PASS=
FLASHBOTS_AUTH_KEY=

# ── Keystores (docker secrets — must be real files on VPS) ────────────────────
EXECUTION_KEYSTORE_FILE=./infra/dev-keystore.json
SUPERADMIN_KEYSTORE_FILE=./infra/dev-keystore.json
SUPERADMIN_KEYSTORE_PASS=

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
DEFAULT_MAX_TRADE_SIZE_USD=1000
DEFAULT_MIN_NET_PROFIT_USD=5
DEFAULT_MAX_GAS_GWEI=100
