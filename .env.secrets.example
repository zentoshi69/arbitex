# ArbitEx secrets — copy to .env.secrets and fill values
# NEVER commit .env.secrets. Load with: --env-file .env.secrets

# ── Database & Redis ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
REDIS_PASSWORD=
DATABASE_URL=postgresql://arbitex:YOUR_POSTGRES_PASSWORD@postgres:5432/arbitex
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
OPERATOR_API_KEY=
OPERATOR_PASSWORD_HASH=

# ── Keystore paths (host paths; Docker mounts these as secrets) ─────────────────
EXECUTION_KEYSTORE_FILE=
SUPERADMIN_KEYSTORE_FILE=
EXECUTION_WALLET_KEYSTORE_PASS=
SUPERADMIN_KEYSTORE_PASS=

# ── Private RPC URLs (QuickNode, Alchemy, etc.) ───────────────────────────────
# All blockchain reads/writes use these. Add more networks as needed.
AVALANCHE_RPC_URL=
AVALANCHE_WSS_URL=
ETHEREUM_RPC_URL=
ETHEREUM_ARCHIVE_RPC_URL=
ETHEREUM_WSS_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
