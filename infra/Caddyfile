{
  email {$ACME_EMAIL}
}

{$DASHBOARD_DOMAIN} {
  encode zstd gzip
  header {
    # Security headers (app also sets many via Next config)
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  }
  reverse_proxy web:3000
}

{$API_DOMAIN} {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  }
  reverse_proxy api:3001
}

