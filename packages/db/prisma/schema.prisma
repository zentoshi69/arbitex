// ArbitEx — Prisma Schema
// PostgreSQL 15 | All timestamps UTC

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, pgcrypto]
}

// ── Reference Data ──────────────────────────────────────────────────────────

model Chain {
  id         Int      @id @default(autoincrement())
  chainId    Int      @unique @map("chain_id")
  name       String
  shortName  String   @map("short_name")
  rpcUrl     String   @map("rpc_url")
  isEnabled  Boolean  @default(true) @map("is_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  venues  Venue[]
  tokens  Token[]

  @@map("chains")
}

model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chainId       Int      @map("chain_id")
  name          String
  protocol      String   // "uniswap_v3" | "sushiswap_v2" | ...
  routerAddress String   @map("router_address")
  factoryAddress String? @map("factory_address")
  isEnabled     Boolean  @default(true) @map("is_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  chain         Chain    @relation(fields: [chainId], references: [chainId])
  pools         Pool[]

  @@unique([chainId, name])
  @@index([chainId, isEnabled])
  @@map("venues")
}

model Token {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chainId       Int      @map("chain_id")
  address       String
  symbol        String
  name          String
  decimals      Int
  logoUri       String?  @map("logo_uri")
  // Screening flags (JSON array of TokenFlag values)
  flags         String[] @default([])
  isEnabled     Boolean  @default(true) @map("is_enabled")
  isTracked     Boolean  @default(false) @map("is_tracked")
  accentColor   String?  @map("accent_color")
  lastScreened  DateTime? @map("last_screened")
  cooldownUntil DateTime? @map("cooldown_until")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  chain              Chain           @relation(fields: [chainId], references: [chainId])
  poolsAsToken0      Pool[]          @relation("Token0Pools")
  poolsAsToken1      Pool[]          @relation("Token1Pools")
  opportunities      Opportunity[]
  riskEvents         RiskEvent[]
  walletBalances     WalletBalance[]

  @@unique([chainId, address])
  @@index([chainId, isEnabled])
  @@index([chainId, isTracked])
  @@index([address])
  @@map("tokens")
}

// ── Pool Data ───────────────────────────────────────────────────────────────

model Pool {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId        String   @map("venue_id") @db.Uuid
  token0Id       String   @map("token0_id") @db.Uuid
  token1Id       String   @map("token1_id") @db.Uuid
  poolAddress    String   @map("pool_address")
  feeBps         Int      @map("fee_bps")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  venue          Venue          @relation(fields: [venueId], references: [id])
  token0         Token          @relation("Token0Pools", fields: [token0Id], references: [id])
  token1         Token          @relation("Token1Pools", fields: [token1Id], references: [id])
  snapshots      PoolSnapshot[]
  routeSteps     OpportunityRoute[]
  liquidityMap   LiquidityMap?

  @@unique([venueId, token0Id, token1Id, feeBps])
  @@index([venueId, isActive])
  @@index([token0Id, token1Id])
  @@map("pools")
}

model PoolSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poolId          String   @map("pool_id") @db.Uuid
  price0Per1      Decimal  @map("price0_per1") @db.Decimal(36, 18)
  price1Per0      Decimal  @map("price1_per0") @db.Decimal(36, 18)
  liquidityUsd    Decimal  @map("liquidity_usd") @db.Decimal(20, 4)
  sqrtPriceX96    String?  @map("sqrt_price_x96")
  tick            Int?
  volumeUsd24h    Decimal? @map("volume_usd_24h") @db.Decimal(20, 4)
  timestamp       DateTime @default(now())

  pool            Pool     @relation(fields: [poolId], references: [id])

  @@index([poolId, timestamp(sort: Desc)])
  @@map("pool_snapshots")
}

// ── Opportunity ─────────────────────────────────────────────────────────────

model Opportunity {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  state             String           // OpportunityState enum
  tokenId           String?          @map("token_id") @db.Uuid
  tokenInAddress    String           @map("token_in_address")
  tokenOutAddress   String           @map("token_out_address")
  tokenInSymbol     String           @map("token_in_symbol")
  tokenOutSymbol    String           @map("token_out_symbol")
  tradeSizeUsd      Decimal          @map("trade_size_usd") @db.Decimal(20, 4)
  grossSpreadUsd    Decimal          @map("gross_spread_usd") @db.Decimal(20, 4)
  gasEstimateUsd    Decimal          @map("gas_estimate_usd") @db.Decimal(20, 4)
  venueFeesUsd      Decimal          @map("venue_fees_usd") @db.Decimal(20, 4)
  slippageBufferUsd Decimal          @map("slippage_buffer_usd") @db.Decimal(20, 4)
  failureBufferUsd  Decimal          @map("failure_buffer_usd") @db.Decimal(20, 4)
  netProfitUsd      Decimal          @map("net_profit_usd") @db.Decimal(20, 4)
  netProfitBps      Decimal          @map("net_profit_bps") @db.Decimal(10, 4)
  buyVenueId        String           @map("buy_venue_id") @db.Uuid
  sellVenueId       String           @map("sell_venue_id") @db.Uuid
  buyVenueName      String           @map("buy_venue_name")
  sellVenueName     String           @map("sell_venue_name")
  fingerprint       String           // SHA-256 for dedup
  riskDecision      Json?            @map("risk_decision")
  detectedAt        DateTime         @default(now()) @map("detected_at")
  expiresAt         DateTime?        @map("expires_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  token             Token?           @relation(fields: [tokenId], references: [id])
  routes            OpportunityRoute[]
  execution         Execution?

  @@index([state, detectedAt(sort: Desc)])
  @@index([fingerprint])
  @@index([tokenId, detectedAt(sort: Desc)])
  @@index([netProfitUsd(sort: Desc)])
  @@map("opportunities")
}

model OpportunityRoute {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId String      @map("opportunity_id") @db.Uuid
  stepIndex     Int         @map("step_index")
  poolId        String      @map("pool_id") @db.Uuid
  venueId       String      @map("venue_id") @db.Uuid
  venueName     String      @map("venue_name")
  tokenIn       String      @map("token_in")
  tokenOut      String      @map("token_out")
  amountIn      String      @map("amount_in")   // bigint as string
  amountOut     String      @map("amount_out")  // bigint as string
  feeBps        Int         @map("fee_bps")

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  pool          Pool        @relation(fields: [poolId], references: [id])

  @@index([opportunityId, stepIndex])
  @@map("opportunity_routes")
}

// ── Execution ───────────────────────────────────────────────────────────────

model Execution {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId  String    @unique @map("opportunity_id") @db.Uuid
  state          String    // ExecutionState enum
  walletAddress  String    @map("wallet_address")
  txHash         String?   @map("tx_hash")
  blockNumber    Int?      @map("block_number")
  gasUsed        String?   @map("gas_used")   // bigint as string
  gasPrice       String?   @map("gas_price")  // bigint as string
  gasCostUsd     Decimal?  @map("gas_cost_usd") @db.Decimal(20, 4)
  pnlUsd         Decimal?  @map("pnl_usd") @db.Decimal(20, 4)
  failureReason  String?   @map("failure_reason")
  failureCode    String?   @map("failure_code")
  retryCount     Int       @default(0) @map("retry_count")
  submittedAt    DateTime? @map("submitted_at")
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  opportunity    Opportunity   @relation(fields: [opportunityId], references: [id])
  transactions   Transaction[]

  @@index([state, createdAt(sort: Desc)])
  @@index([txHash])
  @@index([walletAddress, createdAt(sort: Desc)])
  @@map("executions")
}

model Transaction {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId  String    @map("execution_id") @db.Uuid
  nonce        Int
  rawTx        String    @map("raw_tx")  // hex encoded signed tx
  bundleHash   String?   @map("bundle_hash")
  submittedAt  DateTime  @default(now()) @map("submitted_at")
  confirmedAt  DateTime? @map("confirmed_at")
  droppedAt    DateTime? @map("dropped_at")

  execution    Execution @relation(fields: [executionId], references: [id])

  @@index([executionId])
  @@index([nonce])
  @@map("transactions")
}

// ── Balances ─────────────────────────────────────────────────────────────────

model WalletBalance {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress String   @map("wallet_address")
  tokenId       String   @map("token_id") @db.Uuid
  balanceWei    String   @map("balance_wei")  // bigint as string
  usdValue      Decimal  @map("usd_value") @db.Decimal(20, 4)
  updatedAt     DateTime @updatedAt @map("updated_at")

  token         Token    @relation(fields: [tokenId], references: [id])

  @@unique([walletAddress, tokenId])
  @@index([walletAddress])
  @@map("wallet_balances")
}

// ── Risk ─────────────────────────────────────────────────────────────────────

model RiskEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType    String   @map("event_type")
  severity     String   // RiskSeverity enum
  tokenId      String?  @map("token_id") @db.Uuid
  venueId      String?  @map("venue_id") @db.Uuid
  details      Json
  resolved     Boolean  @default(false)
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  token        Token?   @relation(fields: [tokenId], references: [id])

  @@index([severity, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("risk_events")
}

model ConfigOverride {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String    @unique
  value      String
  updatedBy  String    @map("updated_by")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("config_overrides")
}

// ── Liquidity Map ────────────────────────────────────────────────────────────

model LiquidityMap {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poolId          String   @map("pool_id") @db.Uuid
  poolAddress     String   @map("pool_address")
  poolType        String   @map("pool_type")  // "v2" | "v3" | "solidly_v2"
  chainId         Int      @map("chain_id")
  data            Json     // tick-level or reserve liquidity map
  scanFromBlock   BigInt   @map("scan_from_block")
  scanToBlock     BigInt   @map("scan_to_block")
  eventCount      Int      @default(0) @map("event_count")
  builtAt         DateTime @default(now()) @map("built_at")
  refreshedAt     DateTime @default(now()) @map("refreshed_at")

  pool            Pool     @relation(fields: [poolId], references: [id])

  @@unique([poolId])
  @@index([chainId, poolType])
  @@map("liquidity_maps")
}

// ── Audit ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String   // e.g. "RISK_CONFIG_UPDATED", "KILL_SWITCH_ACTIVATED"
  actor       String   // user id or "system"
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  diff        Json?    // { before: ..., after: ... }
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actor, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}
